@using Microsoft.AspNetCore.Components.Web
@inject EditorService EditorService;
@inject InkStoryService InkStoryService;
@inject AssetsService AssetsService;
@inject PdfService PdfService;
@inject DiagramService DiagramService;
@inject MoodboardService MoodboardService;
@inherits DevHotReloadComponentBase;

<div class="workspace-layout">

    <div class="workspace-divider @(_dragTarget == DragTarget.Asset ? "dragging" : null)"
         @onpointerdown="e => StartDrag(e, DragTarget.Asset)"
         title="Drag to resize">
    </div>

    <!-- ── EDITOR COLUMN ── -->
    <div class="workspace-col workspace-editor">
        @switch (EditorService.ActiveEditor)
        {
            case EditorType.Ink:
                <InkEditorComponent></InkEditorComponent>
                break;
            case EditorType.Markdown:
                <MarkdownEditorComponent></MarkdownEditorComponent>
                break;
            default:
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" NoIcon="true" Class="my-2">
                    Failed to load editor.
                </MudAlert>
                break;
        }
    </div>

    <!-- ── EDITOR / PREVIEW DIVIDER ── -->
    <div class="workspace-divider @(_dragTarget == DragTarget.Preview ? "dragging" : null)"
         @onpointerdown="e => StartDrag(e, DragTarget.Preview)"
         title="Drag to resize">
        <button class="workspace-divider-btn" title="@(_previewCollapsed ? "Show preview" : "Hide preview")"
                @onclick="TogglePreview" @onclick:stopPropagation="true" @onpointerdown:stopPropagation="true">
            <MudIcon Icon="@(_previewCollapsed ? Icons.Material.Sharp.ChevronLeft : Icons.Material.Sharp.ChevronRight)"
                     Size="MudBlazor.Size.Small"/>
        </button>
    </div>

    <!-- ── PREVIEW COLUMN ── -->
    <div class="workspace-col workspace-preview @(_previewCollapsed ? "collapsed" : null) @(_fullscreen ? "fullscreen" : null)" style="@PreviewStyle">
        <MudTabs MinimumTabWidth="60px" KeepPanelsAlive="true" @bind-ActivePanelIndex="ActiveIndex">
            <MudTabPanel TabContent="@PinnedHeader("Story")">
                <InkStoryRunnerComponent/>
            </MudTabPanel>
            <MudTabPanel Visible="_notesOpen" TabContent="@Header("Notes", () => _notesOpen = false)">
                <MarkdownPreviewComponent/>
            </MudTabPanel>
            <MudTabPanel Visible="_readerOpen" TabContent="@Header("Reader", () => _readerOpen = false, fullscreenable: true)">
                <PdfViewerComponent/>
            </MudTabPanel>
            <MudTabPanel Visible="_graphOpen" TabContent="@Header("Graph", () => _graphOpen = false, fullscreenable: true)">
                <GraphComponent/>
            </MudTabPanel>
            <MudTabPanel Visible="_photoshopOpen" TabContent="@Header("Photoshop", () => _photoshopOpen = false, fullscreenable: true)">
                <PhotoshopComponent/>
            </MudTabPanel>
            <MudTabPanel Visible="_heavyPaintOpen" TabContent="@Header("HeavyPaint", () => _heavyPaintOpen = false, fullscreenable: true)">
                <HeavyPaintComponent Active="_activeIndex == HeavyPaintIndex"/>
            </MudTabPanel>
            <MudTabPanel Visible="_moodboardOpen" TabContent="@Header("Moodboard", () => _moodboardOpen = false, fullscreenable: true)">
                <MoodboardComponent/>
            </MudTabPanel>
            <MudTabPanel Visible="_videoOpen" TabContent="@Header("Video", () => _videoOpen = false, fullscreenable: true)">
                <VideoPlayerComponent/>
            </MudTabPanel>
        </MudTabs>
    </div>

    <!-- Full-viewport catcher so dragging keeps tracking outside the divider -->
    @if (_dragTarget != DragTarget.None)
    {
        <div class="workspace-drag-overlay"
             @onpointermove="OnDrag"
             @onpointerup="EndDrag"
             @onpointerleave="EndDrag"></div>
    }
</div>

@code {
    private int _activeIndex;

    // Bound to MudTabs so we can drop out of fullscreen when the user switches
    // to a tab that isn't fullscreen-eligible (the text previews).
    private int ActiveIndex
    {
        get => _activeIndex;
        set
        {
            _activeIndex = value;
            if (_fullscreen && !IsFullscreenable(value)) _fullscreen = false;
        }
    }

    // ── Fullscreen (in-app maximize) ──
    //    Only the visual previews opt in — text previews (Story, Notes) never do.
    private bool _fullscreen;

    private static bool IsFullscreenable(int index) =>
        index is ReaderIndex or GraphIndex or MoodboardIndex or VideoIndex or HeavyPaintIndex or PhotoshopIndex;

    private void ToggleFullscreen() => _fullscreen = !_fullscreen;

    // ── Column sizing / collapse ──
    private double _assetWidth = 240;
    private double _previewWidth = 800;
    private bool _assetCollapsed;
    private bool _previewCollapsed;

    private enum DragTarget { None, Asset, Preview }
    private DragTarget _dragTarget = DragTarget.None;
    private double _dragStartX;
    private double _dragStartAsset;
    private double _dragStartPreview;

    private const double MinCol = 140;
    private const double MaxCol = 900;

    private string AssetStyle => _assetCollapsed
        ? "flex: 0 0 0; width: 0; min-width: 0;"
        : $"flex: 0 0 {_assetWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)}px; width: {_assetWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)}px;";

    private string PreviewStyle => _previewCollapsed
        ? "flex: 0 0 0; width: 0; min-width: 0;"
        : $"flex: 0 0 {_previewWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)}px; width: {_previewWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)}px;";

    private void StartDrag(PointerEventArgs e, DragTarget target)
    {
        // A collapsed side can't be dragged; use its chevron to reopen first.
        if (target == DragTarget.Asset && _assetCollapsed) return;
        if (target == DragTarget.Preview && _previewCollapsed) return;
        _dragTarget = target;
        _dragStartX = e.ClientX;
        _dragStartAsset = _assetWidth;
        _dragStartPreview = _previewWidth;
    }

    private void OnDrag(PointerEventArgs e)
    {
        if (_dragTarget == DragTarget.None) return;
        var dx = e.ClientX - _dragStartX;
        if (_dragTarget == DragTarget.Asset)
        {
            _assetWidth = Math.Clamp(_dragStartAsset + dx, MinCol, MaxCol);
        }
        else if (_dragTarget == DragTarget.Preview)
        {
            _previewWidth = Math.Clamp(_dragStartPreview - dx, MinCol, MaxCol);
        }
    }

    private void EndDrag(PointerEventArgs e) => _dragTarget = DragTarget.None;

    private void ToggleAsset() => _assetCollapsed = !_assetCollapsed;
    private void TogglePreview() => _previewCollapsed = !_previewCollapsed;

    // ── Content-driven tabs — hidden until their source loads.
    //    The Story tab is pinned: always open, no close button. ──
    private bool _notesOpen;
    private bool _readerOpen;
    private bool _graphOpen;       // opens when a diagram file is selected
    private bool _moodboardOpen;   // opens when a moodboard file is selected
    private bool _photoshopOpen;   // opens when launched from the asset panel's Tools section
    private bool _heavyPaintOpen;  // opens when launched from the asset panel's Tools section
    private bool _videoOpen;       // opens when a video file is selected

    private const int StoryIndex = 0;
    private const int NotesIndex = 1;
    private const int ReaderIndex = 2;
    private const int GraphIndex = 3;
    private const int PhotoshopIndex = 4;
    private const int HeavyPaintIndex = 5;
    private const int MoodboardIndex = 6;
    private const int VideoIndex = 7;

    protected override void OnInitialized()
    {
        EditorService.EditorChanged += OnStateChanged;
        InkStoryService.DialogUpdated += OnStoryContent;
        InkStoryService.ChoicesAdded += OnChoices;
        AssetsService.MarkdownFileSelected += OnMarkdownSelected;
        PdfService.PdfFileSelected += OnPdfSelected;
        DiagramService.DiagramFileSelected += OnDiagramSelected;
        MoodboardService.MoodboardFileSelected += OnMoodboardSelected;
        AssetsService.PhotoshopRequested += OnPhotoshopRequested;
        AssetsService.HeavyPaintRequested += OnHeavyPaintRequested;
        AssetsService.VideoSelected += OnVideoSelected;
    }

    private void OnStoryContent(Endorphins.Models.DialogLine _) => OpenTab(() => { }, StoryIndex);
    private void OnChoices(List<Ink.Runtime.Choice> _) => OpenTab(() => { }, StoryIndex);
    private void OnMarkdownSelected(string _, string __) => OpenTab(() => _notesOpen = true, NotesIndex);
    private void OnPdfSelected(Endorphins.Models.PdfFile _) => OpenTab(() => _readerOpen = true, ReaderIndex);
    private void OnDiagramSelected(string _, string __) => OpenTab(() => _graphOpen = true, GraphIndex);
    private void OnMoodboardSelected(string _, string __) => OpenTab(() => _moodboardOpen = true, MoodboardIndex);
    private void OnPhotoshopRequested() => OpenTab(() => _photoshopOpen = true, PhotoshopIndex);
    private void OnHeavyPaintRequested() => OpenTab(() => _heavyPaintOpen = true, HeavyPaintIndex);
    private void OnVideoSelected(string _) => OpenTab(() => _videoOpen = true, VideoIndex);

    private void OpenTab(Action open, int index) => InvokeAsync(() =>
    {
        open();
        _previewCollapsed = false;   // make sure the preview column is visible
        ActiveIndex = index;         // bring the freshly-loaded preview to the front
        StateHasChanged();
    });

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private RenderFragment PinnedHeader(string label) =>
        @<span class="wtab">
            <span class="wtab-label">@label</span>
        </span>;

    private RenderFragment Header(string label, Action close, bool fullscreenable = false) =>
        @<span class="wtab">
            <span class="wtab-label">@label</span>
            @if (fullscreenable)
            {
                <span class="wtab-fs" title="@(_fullscreen ? "Exit fullscreen" : "Fullscreen")"
                      @onclick="ToggleFullscreen" @onclick:stopPropagation="true">
                    <MudIcon Icon="@(_fullscreen ? Icons.Material.Sharp.FullscreenExit : Icons.Material.Sharp.Fullscreen)"
                             Size="Size.Small"/>
                </span>
            }
            <span class="wtab-close" title="Close"
                  @onclick="@(() => CloseTab(close))" @onclick:stopPropagation="true">
                &#10005;
            </span>
        </span>;

    private void CloseTab(Action close)
    {
        close();
        StateHasChanged();
    }

    public override void Dispose()
    {
        base.Dispose();
        EditorService.EditorChanged -= OnStateChanged;
        InkStoryService.DialogUpdated -= OnStoryContent;
        InkStoryService.ChoicesAdded -= OnChoices;
        AssetsService.MarkdownFileSelected -= OnMarkdownSelected;
        PdfService.PdfFileSelected -= OnPdfSelected;
        DiagramService.DiagramFileSelected -= OnDiagramSelected;
        MoodboardService.MoodboardFileSelected -= OnMoodboardSelected;
        AssetsService.PhotoshopRequested -= OnPhotoshopRequested;
        AssetsService.HeavyPaintRequested -= OnHeavyPaintRequested;
        AssetsService.VideoSelected -= OnVideoSelected;
    }
}
