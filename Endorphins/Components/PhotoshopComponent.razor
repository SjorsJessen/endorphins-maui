@inject IJSRuntime JS
@implements IAsyncDisposable
@inherits DevHotReloadComponentBase;

<div class="photoshop-pane">
    <iframe id="pea" src="@PhotopeaSrc" class="photopea-frame"></iframe>
    <button class="photoshop-export" @onclick="Export">Export edited image</button>
</div>

@code {
    // Photopea's API reads a JSON config from the URL hash on load. The script
    // creates a blank document immediately, so the editor opens ready to work
    // instead of showing the promotional start page. (www.photopea.com/api)
    private static readonly string PhotopeaSrc =
        "https://www.photopea.com#" + Uri.EscapeDataString(
            "{\"script\":\"app.documents.add(1920,1080,72,\\\"Untitled\\\",NewDocumentMode.RGB,DocumentFill.WHITE);\"}");

    private IJSObjectReference? _module;
    private DotNetObjectReference<PhotoshopComponent> _self;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        _self = DotNetObjectReference.Create(this);
        _module = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./js/photopeaInterop.js");
        await _module.InvokeVoidAsync("init", "pea", _self);
    }

    private async Task Export() =>
        await _module!.InvokeVoidAsync("exportPng", "pea");

    [JSInvokable]
    public Task OnImageExported(string base64Png)
    {
        var bytes = Convert.FromBase64String(base64Png);
        // bytes is your PNG — save to disk, upload, show a preview, etc.
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null) await _module.DisposeAsync();
        _self?.Dispose();
    }

}