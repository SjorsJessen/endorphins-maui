@using Endorphins.Models
@using Endorphins.Shared

@inject AssetsService AssetsService;
@inject InkStoryService InkStoryService;
@inject PdfService PdfService;
@inject EditorService EditorService;
@inject FileStorageService StorageService;
@inherits DevHotReloadComponentBase;

<div class="asset-panel">
    <MudToolBar Class="justify-space-between" Dense>
        <MudText>Project</MudText>
        <MudIconButton
            Icon="@Icons.Material.Sharp.FolderOpen"
            Variant="Variant.Text"
            Color="Color.Inherit"
            Size="Size.Small"
            HtmlTag="label"
            for="folderInput"
            OnClick="OpenProject"
        />
    </MudToolBar>
    <MudDivider></MudDivider>
    <MudTreeView T="string" Dense Hover ExpandOnClick>
        @if (_tree.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="pa-3" Style="color: var(--text-dim);">
                No project loaded.
            </MudText>
        }
        else
        {
            @foreach (var node in _tree)
            {
                <AssetTreeNodeComponent Node="node" OnFileActivated="OnFileActivated"/>
            }
        }
    </MudTreeView>

    @if (_isPreviewPanelActive)
    {
        <div class="asset-preview">
            <div class="asset-preview-header">
                <span class="asset-preview-name">@_previewName</span>
                <button class="asset-preview-close" @onclick="ClosePreview" title="Close">&#10005;</button>
            </div>
            <div class="asset-preview-body">
                @switch (_previewKind)
                {
                    case PreviewKind.Image:
                        <img class="asset-preview-img" src="@_previewData" alt="@_previewName"/>
                        break;
                    case PreviewKind.Audio:
                        <audio class="asset-preview-audio" controls autoplay src="@_previewData"></audio>
                        break;
                    case PreviewKind.Json:
                        <pre class="asset-preview-json">@((MarkupString)_previewJsonHtml)</pre>
                        break;
                    default:
                        <span class="asset-preview-empty">No preview available.</span>
                        break;
                }
            </div>
        </div>
    }
</div>

@code {
    private enum PreviewKind { None, Image, Audio, Json }

    private bool _isPreviewPanelActive;
    private PreviewKind _previewKind;
    private string? _previewName;
    private string? _previewData;      // data: URI for image / audio
    private string _previewJsonHtml = string.Empty;
    private List<AssetNode> _tree = [];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        StorageService.FilesLoaded += OnFilesLoaded;
        if (StorageService.FilePaths.Count > 0)
        {
            RebuildTree(StorageService.FilePaths);
        }
    }

    private void OnFilesLoaded(List<string> files) => InvokeAsync(() =>
    {
        RebuildTree(files);
        StateHasChanged();
    });

    private async Task OpenProject()
    {
        await StorageService.PickProjectFolderAsync();
        StorageService.SetFilePathsAsync();
    }

    /// <summary>Turns the flat relative paths into a nested folder/file tree.</summary>
    private void RebuildTree(IEnumerable<string> paths)
    {
        var root = new AssetNode { IsDirectory = true };
        foreach (var path in paths.Where(p => !string.IsNullOrWhiteSpace(p)))
        {
            var parts = path.Split(['/', '\\'], StringSplitOptions.RemoveEmptyEntries);
            var current = root;
            for (var i = 0; i < parts.Length; i++)
            {
                var isFile = i == parts.Length - 1;
                var name = parts[i];
                var existing = current.Children
                    .FirstOrDefault(c => c.Name == name && c.IsDirectory == !isFile);
                if (existing is null)
                {
                    existing = new AssetNode
                    {
                        Name = name,
                        IsDirectory = !isFile,
                        Path = string.Join('/', parts.Take(i + 1))
                    };
                    current.Children.Add(existing);
                }
                current = existing;
            }
        }
        SortNode(root);
        _tree = root.Children;
    }

    /// <summary>Folders first, then files, each group alphabetical.</summary>
    private static void SortNode(AssetNode node)
    {
        node.Children.Sort((a, b) => a.IsDirectory != b.IsDirectory
            ? (a.IsDirectory ? -1 : 1)
            : string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase));
        foreach (var child in node.Children)
        {
            SortNode(child);
        }
    }

    /// <summary>Dispatches a clicked file to the right viewer by extension.</summary>
    private async Task OnFileActivated(string relativePath)
    {
        var ext = System.IO.Path.GetExtension(relativePath).ToLowerInvariant();
        switch (ext)
        {
            case ".ink":
                SelectInkScript(relativePath);
                break;
            case ".md":
                SelectMarkdown(relativePath);
                break;
            case ".pdf":
                await OpenPdf(relativePath);
                break;
            case ".mp4" or ".mkv" or ".webm" or ".mov":
                PlayVideo(relativePath);
                break;
            default:
                await PreviewAsync(relativePath);
                break;
        }
    }

    public override void Dispose()
    {
        base.Dispose();
        StorageService.FilesLoaded -= OnFilesLoaded;
    }
    
    private async Task OpenPdf(string filePath)
    {
        try
        {
            var content = await StorageService.ReadFileAsBytesAsync(filePath);
            var pdfFile = new PdfFile
            {
                Name = filePath,
                Content = content
            };
            PdfService.SelectPdfFile(pdfFile);
            PdfService.PdfFileSelected?.Invoke(pdfFile);
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }
    }    
    
    private async void PlayVideo(string filePath)
    {
        try
        {
            AssetsService.VideoSelected?.Invoke(filePath);
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }
    }
    
    private async void SelectMarkdown(string filePath)
    {
        try
        {
            var contents = await StorageService.ReadFileAsTextAsync(filePath);
            AssetsService.MarkdownFileSelected?.Invoke(filePath, contents);
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }

        EditorService.SetEditor(EditorType.Markdown);
        StateHasChanged();
    }    
    
    private async void SelectInkScript(string filePath)
    {
        try
        {
            var fileContents = await StorageService.ReadFileAsTextAsync(filePath);
            InkStoryService.ActiveScriptPath = filePath;
            InkStoryService.SetContent(fileContents);
            InkStoryService.InkScriptSelected?.Invoke(fileContents);
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }

        EditorService.SetEditor(EditorType.Ink);
        StateHasChanged();
    }
    
    /// <summary>Loads an image/audio/JSON file into the themed preview panel.</summary>
    private async Task PreviewAsync(string filePath)
    {
        _previewName = System.IO.Path.GetFileName(filePath);
        var ext = System.IO.Path.GetExtension(filePath).ToLowerInvariant();
        try
        {
            switch (ext)
            {
                case ".json":
                    var json = await StorageService.ReadFileAsTextAsync(filePath);
                    _previewJsonHtml = JsonPreview.Highlight(json);
                    _previewKind = PreviewKind.Json;
                    break;
                case ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" or ".bmp":
                    _previewData = await ReadAsDataUriAsync(filePath, ext);
                    _previewKind = PreviewKind.Image;
                    break;
                case ".mp3" or ".wav" or ".ogg" or ".m4a" or ".flac":
                    _previewData = await ReadAsDataUriAsync(filePath, ext);
                    _previewKind = PreviewKind.Audio;
                    break;
                default:
                    _previewKind = PreviewKind.None;
                    break;
            }
            _isPreviewPanelActive = true;
            StateHasChanged();
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }
    }

    private async Task<string> ReadAsDataUriAsync(string filePath, string ext)
    {
        var bytes = await StorageService.ReadFileAsBytesAsync(filePath);
        return $"data:{MimeType(ext)};base64,{Convert.ToBase64String(bytes)}";
    }

    private void ClosePreview()
    {
        _isPreviewPanelActive = false;
        _previewData = null;
        _previewJsonHtml = string.Empty;
        _previewKind = PreviewKind.None;
    }

    private static string MimeType(string ext) => ext switch
    {
        ".png" => "image/png",
        ".jpg" or ".jpeg" => "image/jpeg",
        ".gif" => "image/gif",
        ".webp" => "image/webp",
        ".bmp" => "image/bmp",
        ".mp3" => "audio/mpeg",
        ".wav" => "audio/wav",
        ".ogg" => "audio/ogg",
        ".m4a" => "audio/mp4",
        ".flac" => "audio/flac",
        _ => "application/octet-stream"
    };

}

