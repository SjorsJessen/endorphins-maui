@using Endorphins.Models
@using Ink.Runtime
@inject FileStorageService StorageService
@inject InkStoryService StoryService
@inject IJSRuntime JS

@inherits DevHotReloadComponentBase

<div class="ink-story-runner">
    <div class="story-scroll overflow-auto" @ref="_scrollRef">
        @if (!StoryService.IsStoryLoaded && StoryService.DialogLines.Count == 0)
        {
            <div class="story-empty">No story has been loaded. Load a project.</div>
        }
        else
        {
            foreach (var line in StoryService.DialogLines)
            {
                switch (line.Type){
                    case DialogType.Narrator:
                        <div class="dialogue-line">
                            <div class="dialogue-bubble">
                                <span class="story-p">@line.Line</span>
                            </div>
                        </div>
                        break;
                    case DialogType.Main:
                        <div class="dialogue-line">
                            <img class="dialogue-portrait" srcset="Assets/endorphins-icon.svg" alt="portrait" />
                            <div class="dialogue-bubble">
                                <span class="dialogue-name">@line.Speaker</span>
                                <span class="story-p">@line.Line</span>
                            </div>
                        </div>
                        break;
                    case DialogType.Npc:
                        <div class="dialogue-line dialogue-line-npc">
                            <div class="dialogue-bubble">
                                <span class="dialogue-name">@line.Speaker</span>
                                <span class="story-p">@line.Line</span>
                            </div>
                            <img class="dialogue-portrait" srcset="Assets/endorphins-icon.svg" alt="portrait" />
                        </div>
                        break;
                    case DialogType.Title:
                        <div class="dialogue-title justify-content-center" style="font-size: 28px; font-weight: bold; text-align: center; color: white; margin-top: 1rem; margin-bottom: 1rem;">
                            <span>@line.Line</span>
                        </div>
                        break;
                    case DialogType.Divider:
                        <div class="dialogue-divider justify-content-center" style="font-size: 36px; font-weight: bold; text-align: center; color: lightgray; margin-top: 1rem; margin-bottom: 1rem;">
                            <span>@line.Line</span>
                        </div>
                        break;
                }
            }   
            @if (StoryService.Choices.Count > 0)
            {
                <div class="choices-panel">
                    @foreach (var choice in StoryService.Choices)
                    {
                        <button class="choice-btn" @onclick="() => StoryService.MakeChoice(choice.index)">
                            <span class="choice-num">@(choice.index + 1)</span>
                            <span>@choice.text</span>
                        </button>
                    }
                </div>
            }
        }
    </div>

    @if (StoryService.IsMainScriptActive)
    {
        <div class="story-footer">
            <MudTooltip Text="Compile and run from the beginning" Arrow="true" Placement="Placement.Top">
                <MudIconButton Icon="@Icons.Material.Sharp.PlayArrow" Color="Color.Info" Size="Size.Medium"
                               OnClick="Run" />
            </MudTooltip>
            <MudTooltip Text="Continue" Arrow="true" Placement="Placement.Top">
                <MudIconButton Icon="@Icons.Material.Sharp.FastForward" Color="Color.Inherit" Size="Size.Medium"
                               Disabled="!StoryService.IsStoryLoaded" OnClick="StoryService.ContinueStory" />
            </MudTooltip>
            <MudTooltip Text="Restart story" Arrow="true" Placement="Placement.Top">
                <MudIconButton Icon="@Icons.Material.Sharp.Refresh" Color="Color.Inherit" Size="Size.Medium"
                               Disabled="!StoryService.IsStoryLoaded" OnClick="Restart" />
            </MudTooltip>
        </div>
    }
</div>

@code {
    private ElementReference _scrollRef;
    private int _renderedEntryCount;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        StoryService.ChoicesAdded += OnStateChanged;
        StoryService.DialogUpdated += OnStateChanged;
        StoryService.StoryReset += OnStateChanged;
        StoryService.ChoicesReset += OnStateChanged;
        StoryService.InkScriptSelected += OnScriptSelected;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Keep the newest dialogue line / choices in view as the story advances.
        var entryCount = StoryService.DialogLines.Count + StoryService.Choices.Count;
        if (entryCount != _renderedEntryCount)
        {
            _renderedEntryCount = entryCount;
            await JS.InvokeVoidAsync("scrollStoryToEnd", _scrollRef);
        }
    }

    private void Run()
    {
        if (StorageService.Root is null) return;
        StoryService.Run(StorageService.Root, StoryService.ActiveScriptPath);
    }

    private void Restart()
    {
        StoryService.ResetStory();
        StoryService.ContinueStory();
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OnStateChanged(DialogLine _) => OnStateChanged();

    private void OnStateChanged(List<Choice> _) => OnStateChanged();

    private void OnScriptSelected(string _) => OnStateChanged();

    public override void Dispose()
    {
        base.Dispose();
        StoryService.ChoicesAdded -= OnStateChanged;
        StoryService.DialogUpdated -= OnStateChanged;
        StoryService.StoryReset -= OnStateChanged;
        StoryService.ChoicesReset -= OnStateChanged;
        StoryService.InkScriptSelected -= OnScriptSelected;
    }
}
