<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <!-- See https://aka.ms/maui-publish-app-store#add-entitlements for more information about adding entitlements.-->
    <dict>
        <!-- App Sandbox must be enabled to distribute a MacCatalyst app through the Mac App Store. -->
        <key>com.apple.security.app-sandbox</key>
        <true/>
        <!-- When App Sandbox is enabled, this value is required to open outgoing network connections. -->
        <key>com.apple.security.network.client</key>
        <true/>
        <!-- LocalMediaServer listens on a loopback TCP port. App Sandbox gates *accepting*
             connections behind this entitlement, loopback included — without it the Release
             build's PDF, video and image previews all fail while Debug (sandbox-free
             entitlements) works fine. -->
        <key>com.apple.security.network.server</key>
        <true/>
        <key>com.apple.security.files.user-selected.read-write</key>
        <true/>
        <!-- Lets ProjectBookmarkStore persist a security-scoped bookmark, so the last
             project reopens on launch. Without it the sandbox re-grants nothing and the
             remembered folder comes back unreadable. -->
        <key>com.apple.security.files.bookmarks.app-scope</key>
        <true/>
    </dict>
</plist>

