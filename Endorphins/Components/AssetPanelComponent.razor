@using Endorphins.Models
@using Endorphins.Shared

@inject AssetsService AssetsService;
@inject InkStoryService InkStoryService;
@inject PdfService PdfService;
@inject EditorService EditorService;
@inject FileStorageService StorageService;
@inject DiagramService DiagramService;
@inject MoodboardService MoodboardService;
@inject LocalMediaServer MediaServer;
@inherits DevHotReloadComponentBase;

@* Side panel: the Asset Menu is the underlying layer; the Preview Window is a
   sibling fixed to the side panel's bottom, overlaying the menu so the assets
   scroll underneath it. *@
<div class="side-panel">
    <div class="asset-panel">
        <MudToolBar Class="justify-space-between" Dense>
            <MudText>Project</MudText>
            <MudIconButton Icon="@Icons.Material.Sharp.FolderOpen" Variant="Variant.Text" Color="Color.Inherit"
                           Size="Size.Small" HtmlTag="label" for="folderInput" OnClick="OpenProject" />
        </MudToolBar>
        <MudDivider></MudDivider>

        @if (!_projectLoaded)
        {
            <MudText Typo="Typo.body1" Class="pa-3" Style="color: var(--text-dim);">
                No project loaded.
            </MudText>
        }
        else
        {
            <div class="asset-scroll">
                <div class="asset-section-label">Workspace</div>
                <MudDivider />
                <MudTreeView T="string" Dense Hover ExpandOnClick>
                    @foreach (var node in _workspaceTree)
                    {
                        <AssetTreeNodeComponent Node="node" OnFileActivated="OnFileActivated" OnCreateFile="CreateFileInFolder"
                                                OnRenameFile="RenameFile" />
                    }
                </MudTreeView>

                <div class="asset-section-label">Assets</div>
                <MudDivider />
                <MudTreeView T="string" Dense Hover ExpandOnClick>
                    @if (_assetsTree.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="px-3 py-2" Style="color: var(--text-dim); font-style: italic;">
                            No assets.
                        </MudText>
                    }
                    else
                    {
                        @foreach (var node in _assetsTree)
                        {
                            <AssetTreeNodeComponent Node="node" OnFileActivated="OnFileActivated" OnCreateFile="CreateFileInFolder"
                                                    OnRenameFile="RenameFile" />
                        }
                    }
                </MudTreeView>

                <div class="asset-tools">
                    <div class="asset-section-label">Tools</div>
                    <MudDivider />
                    <button class="asset-tool-item" @onclick="OpenPhotoshop" title="Open Photopea image editor">
                        <MudIcon Icon="@Icons.Material.Sharp.Brush" Class="asset-row-icon" Size="Size.Small" />
                        <span class="asset-row-name">Photopea</span>
                    </button>
                    <button class="asset-tool-item" @onclick="OpenHeavyPaint" title="Open HeavyPaint">
                        <MudIcon Icon="@Icons.Material.Sharp.Palette" Class="asset-row-icon" Size="Size.Small" />
                        <span class="asset-row-name">HeavyPaint</span>
                    </button>
                </div>
            </div>
        }
    </div>

    @if (_isPreviewPanelActive)
    {
        <div class="asset-preview">
            <div class="asset-preview-header">
                <span class="asset-preview-name">@_previewName</span>
                <button class="asset-preview-close" @onclick="ClosePreview" title="Close">&#10005;</button>
            </div>
            <div class="asset-preview-body">
                @switch (_previewKind)
                {
                    case PreviewKind.Image:
                        <img class="asset-preview-img" src="@_previewData" alt="@_previewName" />
                        break;
                    case PreviewKind.Audio:
                        <audio class="asset-preview-audio" controls autoplay src="@_previewData"></audio>
                        break;
                    case PreviewKind.Json:
                        <pre class="asset-preview-json">@((MarkupString)_previewJsonHtml)</pre>
                        break;
                    default:
                        <span class="asset-preview-empty">No preview available.</span>
                        break;
                }
            </div>
        </div>
    }
</div>

@code {
    private enum PreviewKind { None, Image, Audio, Json }

    private bool _isPreviewPanelActive;
    private PreviewKind _previewKind;
    private string? _previewName;
    private string? _previewData; // loopback media-server URL for image / audio
    private string _previewJsonHtml = string.Empty;
    private bool _projectLoaded;
    private List<AssetNode> _workspaceTree = [];
    private List<AssetNode> _assetsTree = [];

    // Dynamic (editable) categories shown under "Workspace", in this order.
    private static readonly string[] WorkspaceCategories = ["scripts", "notes", "diagrams", "moodboards"];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        StorageService.FilesLoaded += OnFilesLoaded;
        if (StorageService.Root is not null)
        {
            RebuildTree(StorageService.FilePaths);
        }
    }

    private void OnFilesLoaded(List<string> files) => InvokeAsync(() =>
    {
        RebuildTree(files);
        StateHasChanged();
    });

    private async Task OpenProject()
    {
        // Cancelling the picker is a no-op: don't re-enumerate (there may be no project
        // yet, and if there is one it hasn't changed).
        if (await StorageService.PickProjectFolderAsync() is null) return;
        StorageService.SetFilePathsAsync();
    }

    /// <summary>Turns the flat relative paths into a nested folder/file tree.</summary>
    private void RebuildTree(IEnumerable<string> paths)
    {
        var root = new AssetNode { IsDirectory = true };
        foreach (var path in paths.Where(p => !string.IsNullOrWhiteSpace(p)))
        {
            var parts = path.Split(['/', '\\'], StringSplitOptions.RemoveEmptyEntries);
            var current = root;
            for (var i = 0; i < parts.Length; i++)
            {
                var isFile = i == parts.Length - 1;
                var name = parts[i];
                var existing = current.Children
                    .FirstOrDefault(c => c.Name == name && c.IsDirectory == !isFile);
                if (existing is null)
                {
                    existing = new AssetNode
                    {
                        Name = name,
                        IsDirectory = !isFile,
                        Path = string.Join('/', parts.Take(i + 1))
                    };
                    current.Children.Add(existing);
                }
                current = existing;
            }
        }
        foreach (var category in WorkspaceCategories)
        {
            EnsureCategory(root, category);
        }
        SortNode(root);

        // Workspace = the dynamic categories (in preferred order); Assets = the rest.
        _workspaceTree = WorkspaceCategories
            .Select(name => root.Children.FirstOrDefault(c =>
                c.IsDirectory && string.Equals(c.Name, name, StringComparison.OrdinalIgnoreCase)))
            .Where(n => n is not null)
            .Select(n => n!)
            .ToList();

        _assetsTree = root.Children
            .Where(c => !WorkspaceCategories.Contains(c.Name, StringComparer.OrdinalIgnoreCase))
            .ToList();

        _projectLoaded = true;
    }

    /// <summary>Guarantees a top-level category folder exists so its + button is always available.</summary>
    private static void EnsureCategory(AssetNode root, string name)
    {
        var exists = root.Children.Any(c =>
            c.IsDirectory && string.Equals(c.Name, name, StringComparison.OrdinalIgnoreCase));
        if (!exists)
        {
            root.Children.Add(new AssetNode { Name = name, IsDirectory = true, Path = name });
        }
    }

    /// <summary>Folders first, then files, each group alphabetical.</summary>
    private static void SortNode(AssetNode node)
    {
        node.Children.Sort((a, b) => a.IsDirectory != b.IsDirectory
            ? (a.IsDirectory ? -1 : 1)
            : string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase));
        foreach (var child in node.Children)
        {
            SortNode(child);
        }
    }

    /// <summary>Dispatches a clicked file to the right viewer by extension.</summary>
    private async Task OnFileActivated(string relativePath)
    {
        var ext = System.IO.Path.GetExtension(relativePath).ToLowerInvariant();
        switch (ext)
        {
            case ".ink":
                SelectInkScript(relativePath);
                break;
            case ".md":
                SelectMarkdown(relativePath);
                break;
            case ".diagram":
                await SelectDiagram(relativePath);
                break;
            case ".moodboard":
                await SelectMoodboard(relativePath);
                break;
            case ".pdf":
                OpenPdf(relativePath);
                break;
            case ".mp4" or ".mkv" or ".webm" or ".mov":
                PlayVideo(relativePath);
                break;
            default:
                await PreviewAsync(relativePath);
                break;
        }
    }

    public override void Dispose()
    {
        base.Dispose();
        StorageService.FilesLoaded -= OnFilesLoaded;
    }

    private void OpenPdf(string filePath)
    {
        // No byte read here — the viewer loads the PDF by URL from the loopback
        // file server, so pdf.js can fetch pages lazily via HTTP range requests.
        var pdfFile = new PdfFile { Name = filePath };
        PdfService.SelectPdfFile(pdfFile);
        PdfService.PdfFileSelected?.Invoke(pdfFile);
    }

    private void PlayVideo(string filePath)
    {
        try
        {
            AssetsService.SelectVideo(filePath);
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }
    }

    private async void SelectMarkdown(string filePath)
    {
        try
        {
            var contents = await StorageService.ReadFileAsTextAsync(filePath);
            AssetsService.SelectMarkdown(filePath, contents);
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }

        EditorService.SetEditor(EditorType.Markdown);
        StateHasChanged();
    }

    private async void SelectInkScript(string filePath)
    {
        try
        {
            var fileContents = await StorageService.ReadFileAsTextAsync(filePath);
            InkStoryService.ActiveScriptPath = filePath;
            InkStoryService.SetContent(fileContents);
            InkStoryService.InkScriptSelected?.Invoke(fileContents);
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }

        EditorService.SetEditor(EditorType.Ink);
        StateHasChanged();
    }

    /// <summary>Creates a new .ink (scripts) or .md (notes) file in the given category folder and opens it.</summary>
    private async Task CreateFileInFolder(AssetNode folder)
    {
        if (StorageService.Root is null) return;

        var ext = string.Equals(folder.Name, "scripts", StringComparison.OrdinalIgnoreCase) ? ".ink"
                : string.Equals(folder.Name, "notes", StringComparison.OrdinalIgnoreCase) ? ".md"
                : string.Equals(folder.Name, "diagrams", StringComparison.OrdinalIgnoreCase) ? ".diagram"
                : string.Equals(folder.Name, "moodboards", StringComparison.OrdinalIgnoreCase) ? ".moodboard"
                : null;
        if (ext is null) return;

        var relPath = $"{folder.Path}/{UniqueFileName(folder.Path, ext)}";
        var initial = ext switch
        {
            ".diagram" => "{\"nodes\":[],\"links\":[]}",
            ".moodboard" => "{\"items\":[],\"nextZ\":1}",
            _ => string.Empty
        };
        try
        {
            await StorageService.WriteFileAsync(relPath, initial);
            StorageService.SetFilePathsAsync(); // re-enumerate → FilesLoaded → tree rebuild

            switch (ext)
            {
                case ".ink":
                    SelectInkScript(relPath);
                    break;
                case ".md":
                    SelectMarkdown(relPath);
                    break;
                case ".diagram":
                    await SelectDiagram(relPath);
                    break;
                case ".moodboard":
                    await SelectMoodboard(relPath);
                    break;
            }
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }
    }

    /// <summary>Opens a diagram file for editing in the Graph tab.</summary>
    private async Task SelectDiagram(string filePath)
    {
        try
        {
            var content = await StorageService.ReadFileAsTextAsync(filePath);
            DiagramService.ActiveDiagramPath = filePath;
            DiagramService.DiagramFileSelected?.Invoke(filePath, content);
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }
    }

    /// <summary>Launches the Photopea tool tab.</summary>
    private void OpenPhotoshop() => AssetsService.PhotoshopRequested?.Invoke();

    /// <summary>Launches the HeavyPaint tool tab.</summary>
    private void OpenHeavyPaint() => AssetsService.HeavyPaintRequested?.Invoke();

    /// <summary>Opens a moodboard file for editing in the Moodboard tab.</summary>
    private async Task SelectMoodboard(string filePath)
    {
        try
        {
            var content = await StorageService.ReadFileAsTextAsync(filePath);
            MoodboardService.ActiveMoodboardPath = filePath;
            MoodboardService.MoodboardFileSelected?.Invoke(filePath, content);
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }
    }

    /// <summary>Renames a file in place, preserving its extension if the new name omits one.</summary>
    private async Task RenameFile((string OldPath, string NewName) req)
    {
        if (StorageService.Root is null) return;

        var oldPath = req.OldPath.Replace('\\', '/');
        var dir = System.IO.Path.GetDirectoryName(oldPath)?.Replace('\\', '/') ?? string.Empty;
        var oldExt = System.IO.Path.GetExtension(oldPath);

        var finalName = System.IO.Path.HasExtension(req.NewName) ? req.NewName : req.NewName + oldExt;
        var newPath = string.IsNullOrEmpty(dir) ? finalName : $"{dir}/{finalName}";
        if (string.Equals(newPath, oldPath, StringComparison.OrdinalIgnoreCase)) return;

        try
        {
            StorageService.RenameFile(oldPath, newPath);
            StorageService.SetFilePathsAsync(); // re-enumerate → tree rebuild

            // Keep the editor pointed at the renamed ink script if it was active.
            if (string.Equals(InkStoryService.ActiveScriptPath.Replace('\\', '/'), oldPath, StringComparison.OrdinalIgnoreCase))
            {
                InkStoryService.ActiveScriptPath = newPath;
            }
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }
    }

    /// <summary>Picks an unused "untitled" name within a folder (untitled.ink, untitled-1.ink, …).</summary>
    private string UniqueFileName(string folderPath, string ext)
    {
        var existing = new HashSet<string>(
            StorageService.FilePaths.Select(p => p.Replace('\\', '/')),
            StringComparer.OrdinalIgnoreCase);

        for (var i = 0; ; i++)
        {
            var candidate = i == 0 ? $"untitled{ext}" : $"untitled-{i}{ext}";
            if (!existing.Contains($"{folderPath}/{candidate}"))
            {
                return candidate;
            }
        }
    }

    /// <summary>Loads an image/audio/JSON file into the themed preview panel.</summary>
    private async Task PreviewAsync(string filePath)
    {
        _previewName = System.IO.Path.GetFileName(filePath);
        var ext = System.IO.Path.GetExtension(filePath).ToLowerInvariant();
        try
        {
            switch (ext)
            {
                case ".json":
                    var json = await StorageService.ReadFileAsTextAsync(filePath);
                    _previewJsonHtml = JsonPreview.Highlight(json);
                    _previewKind = PreviewKind.Json;
                    break;
                // Images and audio stream from the loopback server rather than being
                // inlined: a data: URI costs a full read, a 33% base64 inflation, and a
                // multi-megabyte string through the render diff before the <img> even
                // starts decoding. A URL hands the file straight to WebKit, which loads
                // and decodes it off the UI thread and caches it for repeat selections.
                case ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" or ".bmp":
                    _previewData = MediaServer.Url(filePath);
                    _previewKind = PreviewKind.Image;
                    break;
                case ".mp3" or ".wav" or ".ogg" or ".m4a" or ".flac":
                    _previewData = MediaServer.Url(filePath);
                    _previewKind = PreviewKind.Audio;
                    break;
                default:
                    _previewKind = PreviewKind.None;
                    break;
            }
            _isPreviewPanelActive = true;
            StateHasChanged();
        }
        catch (Exception exc)
        {
            Console.Error.WriteLine(exc);
        }
    }

    private void ClosePreview()
    {
        _isPreviewPanelActive = false;
        _previewData = null;
        _previewJsonHtml = string.Empty;
        _previewKind = PreviewKind.None;
    }

}

