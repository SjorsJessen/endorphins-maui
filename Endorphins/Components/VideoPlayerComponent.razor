@inject AssetsService AssetsService
@inject LocalMediaServer MediaServer
@inject IJSRuntime JS
@implements IAsyncDisposable
@inherits DevHotReloadComponentBase;

<div class="video-player">
    @if (_activeVideo is null)
    {
        <div class="video-empty">No video selected.</div>
    }
    else
    {
        <div class="video-title">@System.IO.Path.GetFileName(_activeVideo)</div>
    }
    <video @ref="_videoRef" controls playsinline class="video-element"></video>
</div>

@code {
    private ElementReference _videoRef;
    private string? _activeVideo;      // project-relative path of the selected video
    private string? _pendingVideo;     // set by the event, loaded in OnAfterRenderAsync

    protected override void OnInitialized()
    {
        base.OnInitialized();
        AssetsService.VideoSelected += OnVideoSelected;

        // Created lazily when the Video tab first opens — after the selection
        // event has already fired — so seed from the persisted selection.
        if (AssetsService.ActiveVideoPath is not null)
        {
            _pendingVideo = AssetsService.ActiveVideoPath;
        }
    }

    private void OnVideoSelected(string relativePath) => InvokeAsync(() =>
    {
        _pendingVideo = relativePath;
        StateHasChanged();
    });

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingVideo is null) return;
        var path = _pendingVideo;
        _pendingVideo = null;
        try
        {
            // Point the <video> at the loopback file server — the WebView streams
            // the file natively (progressive playback + seeking) instead of us
            // pushing the whole clip across the interop bridge.
            var url = MediaServer.Url(path);
            var status = await JS.InvokeAsync<string>("playVideoUrl", _videoRef, url);
            Console.WriteLine($"[VideoPlayer] {path}: {status}");
            _activeVideo = path;
            StateHasChanged();
        }
        catch (Exception e)
        {
            Console.Error.WriteLine(e);
        }
    }

    public async ValueTask DisposeAsync()
    {
        AssetsService.VideoSelected -= OnVideoSelected;
        try
        {
            await JS.InvokeVoidAsync("releaseVideoStream", _videoRef);
        }
        catch (JSDisconnectedException) { /* webview already gone */ }
    }
}
