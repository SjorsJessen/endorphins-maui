@using Endorphins.Models
@implements IAsyncDisposable
@inject IJSRuntime Js
@inject PdfService PdfService
@inject FileStorageService StorageService
@inject LocalMediaServer MediaServer
@inherits DevHotReloadComponentBase;

<div class="pdf-preview">
    @if (!PdfService.HasSelectedPdfFile)
    {
        <div class="pdf-empty">No PDF selected.</div>
    }
    else
    {
        <div class="pdf-toolbar">
            <div class="pdf-tb-group">
                <button class="pdf-tb-btn @(_showOutline ? "active" : null)" title="Toggle outline"
                        @onclick="ToggleOutline" disabled="@(_outline.Count == 0)">
                    <MudIcon Icon="@Icons.Material.Sharp.FormatListBulleted" Size="Size.Small"/>
                </button>
                <button class="pdf-tb-btn" title="Previous page" @onclick="PrevPage">
                    <MudIcon Icon="@Icons.Material.Sharp.KeyboardArrowUp" Size="Size.Small"/>
                </button>
                <span class="pdf-page-label">@_currentPage / @_numPages</span>
                <button class="pdf-tb-btn" title="Next page" @onclick="NextPage">
                    <MudIcon Icon="@Icons.Material.Sharp.KeyboardArrowDown" Size="Size.Small"/>
                </button>
            </div>
            <div class="pdf-tb-group">
                <button class="pdf-tb-btn" title="Highlight selected text" @onclick="HighlightSelection">
                    <MudIcon Icon="@Icons.Material.Sharp.BorderColor" Size="Size.Small"/>
                </button>
                <button class="pdf-tb-btn" title="Zoom out" @onclick="() => Zoom(-0.2)">
                    <MudIcon Icon="@Icons.Material.Sharp.Remove" Size="Size.Small"/>
                </button>
                <span class="pdf-zoom-label">@_zoom%</span>
                <button class="pdf-tb-btn" title="Zoom in" @onclick="() => Zoom(0.2)">
                    <MudIcon Icon="@Icons.Material.Sharp.Add" Size="Size.Small"/>
                </button>
            </div>
        </div>

        <div class="pdf-content-area">
            @if (_showOutline && _outline.Count > 0)
            {
                <div class="pdf-outline-panel">
                    @foreach (var item in _outline)
                    {
                        @RenderOutline(item, 0)
                    }
                </div>
            }
            <div class="pdf-pages-container" @ref="_pagesRef"></div>
        </div>

        @if (_isLoading)
        {
            <div class="pdf-loading">
                <MudProgressCircular Color="Color.Info" Indeterminate="true" Size="Size.Medium" />
                <span class="pdf-loading-title">@_loadingTitle</span>
            </div>
        }
    }
</div>

@code {
    private ElementReference _pagesRef;
    private IJSObjectReference? _module;
    private DotNetObjectReference<PdfViewerComponent>? _dotNetRef;
    private const string JavascriptFilePath = $"./Components/{nameof(PdfViewerComponent)}.razor.js";

    private bool _pendingLoad;
    private bool _isLoading;
    private string? _loadingTitle;
    private int _numPages;
    private int _currentPage = 1;
    private int _zoom = 120;
    private bool _showOutline = true;
    private List<PdfOutlineNode> _outline = [];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        PdfService.PdfFileSelected += OnPdfFileOpened;
        if (PdfService.HasSelectedPdfFile)
        {
            OnPdfFileOpened(PdfService.SelectedPdfFile);
        }
    }

    private string? _activePdfPath;

    /// <summary>Sidecar file storing this PDF's highlights, hidden from the asset
    /// tree because dot-folders are filtered out of enumeration.</summary>
    private static string HighlightsPathFor(string pdfPath) =>
        $".endorphins/highlights/{pdfPath.Replace('\\', '/').Replace('/', '_')}.json";

    private void OnPdfFileOpened(PdfFile pdfFile) => InvokeAsync(() =>
    {
        _activePdfPath = pdfFile.Name;
        _pendingLoad = true;
        _isLoading = true;
        _loadingTitle = System.IO.Path.GetFileName(pdfFile.Name);
        StateHasChanged();   // render the container + loading overlay, then load in OnAfterRenderAsync
    });

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await Js.InvokeAsync<IJSObjectReference>("import", JavascriptFilePath);
        }

        if (_pendingLoad && _module is not null && _activePdfPath is not null)
        {
            _pendingLoad = false;
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try
            {
                // Load by URL from the loopback file server so pdf.js fetches pages
                // lazily over HTTP range requests — no whole-file interop transfer.
                var url = MediaServer.Url(_activePdfPath);
                _numPages = await _module.InvokeAsync<int>("load", url, _pagesRef, _dotNetRef);
                _currentPage = 1;
                _zoom = 120;
                _outline = (await _module.InvokeAsync<PdfOutlineNode[]>("getOutline")).ToList();
                _showOutline = _outline.Count > 0;
                await RestoreHighlightsAsync();
            }
            catch (Exception e)
            {
                Console.Error.WriteLine(e);
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task RestoreHighlightsAsync()
    {
        if (_module is null || _activePdfPath is null || StorageService.Root is null) return;
        try
        {
            var json = await StorageService.ReadFileAsTextAsync(HighlightsPathFor(_activePdfPath));
            await _module.InvokeVoidAsync("setHighlights", json);
        }
        catch (FileNotFoundException) { /* no highlights saved yet */ }
        catch (DirectoryNotFoundException) { /* no highlights saved yet */ }
    }

    private async Task HighlightSelection()
    {
        if (_module is null) return;
        await _module.InvokeAsync<bool>("highlightSelection");
    }

    [JSInvokable]
    public async Task OnHighlightsChanged(string json)
    {
        if (_activePdfPath is null || StorageService.Root is null) return;
        try
        {
            await StorageService.WriteFileAsync(HighlightsPathFor(_activePdfPath), json);
        }
        catch (Exception e)
        {
            Console.Error.WriteLine(e);
        }
    }

    [JSInvokable]
    public Task OnCurrentPageChanged(int page)
    {
        if (page != _currentPage)
        {
            _currentPage = page;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private async Task GoToPage(int? page)
    {
        if (page is not { } p || _module is null) return;
        _currentPage = p;
        await _module.InvokeVoidAsync("scrollToPage", _pagesRef, p);
    }

    private Task PrevPage() => GoToPage(Math.Max(1, _currentPage - 1));
    private Task NextPage() => GoToPage(Math.Min(_numPages, _currentPage + 1));

    private async Task Zoom(double delta)
    {
        if (_module is null) return;
        _zoom = await _module.InvokeAsync<int>("setZoom", _pagesRef, delta);
    }

    private void ToggleOutline() => _showOutline = !_showOutline;

    private RenderFragment RenderOutline(PdfOutlineNode node, int depth) =>
        @<text>
            <button class="pdf-outline-item"
                    style="padding-left:@(10 + depth * 12)px"
                    disabled="@(node.Page is null)"
                    @onclick="() => GoToPage(node.Page)">
                @node.Title
            </button>
            @foreach (var child in node.Items)
            {
                @RenderOutline(child, depth + 1)
            }
        </text>;

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        PdfService.PdfFileSelected -= OnPdfFileOpened;
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose");
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                await Console.Error.WriteLineAsync($"Failed to disconnect {nameof(PdfViewerComponent)}");
            }
        }
        _dotNetRef?.Dispose();
    }
}
