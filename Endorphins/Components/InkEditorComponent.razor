@inject IJSRuntime JS
@inject InkStoryService InkStoryService;
@inject FileStorageService StorageService;
@inherits DevHotReloadComponentBase;

<MudToolBar Dense Class="ink-editor-toolbar">
    @foreach (var element in InkElements)
    {
        <MudTooltip Text="@ElementTooltip(element)" Arrow="true" Placement="Placement.Bottom">
            <MudButton
                Class="ink-tb-btn"
                Variant="Variant.Text"
                Color="Color.Inherit"
                Size="Size.Small"
                OnClick="() => AddInkElement(element.Snippet)">
                <span class="ink-tb-icon">@element.Icon</span>@element.Label
            </MudButton>
        </MudTooltip>
    }

    <div class="ink-fn-dropdown">
        <MudButton
            Class="ink-tb-btn"
            Variant="Variant.Text"
            Color="Color.Inherit"
            Size="Size.Small"
            OnClick="() => _functionsOpen = !_functionsOpen">
            <span class="ink-tb-icon">ƒ</span>Functions<span class="ink-fn-caret">▾</span>
        </MudButton>
        @if (_functionsOpen)
        {
            <div class="ink-fn-backdrop" @onclick="() => _functionsOpen = false"></div>
            <div class="ink-fn-menu">
                <div class="ink-fn-group">External</div>
                @foreach (var fn in InkStoryService.ExternalFunctions)
                {
                    <button class="ink-fn-item" @onclick="() => InsertFunction(fn.Snippet)">
                        <span class="ink-fn-sig">@fn.Signature</span>
                        <span class="ink-fn-desc">@fn.Description</span>
                    </button>
                }
                <div class="ink-fn-group">Built-in</div>
                @foreach (var fn in InkStoryService.BuiltInFunctions)
                {
                    <button class="ink-fn-item" @onclick="() => InsertFunction(fn.Snippet)">
                        <span class="ink-fn-sig">@fn.Signature</span>
                        <span class="ink-fn-desc">@fn.Description</span>
                    </button>
                }
            </div>
        }
    </div>
</MudToolBar>

<StandaloneCodeEditor
    @ref="_editor"
    CssClass="ink-editor"
    ConstructionOptions="EditorConstructionOptions"
    OnDidInit="RegisterEditorShortcuts"
    OnDidChangeModelContent="OnModelContentChanged"
    OnDidChangeCursorPosition="EditorDidChangeCursorPosition"
/>

@if (InkStoryService.Diagnostics.Count > 0)
{
    <div class="ink-error-panel">
        <div class="ink-error-panel-title">Problems (@InkStoryService.Diagnostics.Count)</div>
        <div class="ink-error-panel-list">
            @foreach (var diagnostic in InkStoryService.Diagnostics)
            {
                <div class="ink-error-item @(diagnostic.Type == Ink.ErrorType.Error ? "is-error" : "is-warning")">
                    @diagnostic.Message
                </div>
            }
        </div>
    </div>
}

@code {
    private const string MainInkScriptPath = InkStoryService.MainScriptPath;
    private const int CompileDebounceMs = 700;
    private StandaloneCodeEditor? _editor;
    private CancellationTokenSource? _compileCts;
    private BlazorMonaco.Position _currentCursorPosition = new();
    private sealed record InkSnippet(
        string Icon, string Label, string Tooltip, string Snippet,
        string? Shortcut = null, int? Keybinding = null);

    private const int Cmd = (int)BlazorMonaco.KeyMod.CtrlCmd;
    private const int CmdShift = (int)BlazorMonaco.KeyMod.CtrlCmd | (int)BlazorMonaco.KeyMod.Shift;

    // ⌘C / ⌘V stay copy & paste, so Choice and Variable take the shifted chord.
    private readonly List<InkSnippet> InkElements = new()
    {
        new("===", "Knot",     "Named story section — diverts jump here.", "=== knot === \n", "⌘⇧K",  CmdShift | (int)BlazorMonaco.KeyCode.KeyK),
        new("==",  "Stitch",   "Sub-section within a knot.",               "= stitch = \n ",  "⌘⇧S",  CmdShift | (int)BlazorMonaco.KeyCode.KeyS),
        new("->",  "Divert",   "Jump to a knot, stitch or label.",         "-> divert \n",    "⌘⇧D",  CmdShift | (int)BlazorMonaco.KeyCode.KeyD),
        new("*",   "Choice",   "A choice the player can pick.",            "* choice \n",     "⌘⇧C", CmdShift | (int)BlazorMonaco.KeyCode.KeyC),
        new("VAR", "Variable", "Declare a global variable.",               "VAR ",            "⌘⇧V", CmdShift | (int)BlazorMonaco.KeyCode.KeyV),
        new("#",   "Tag",      "Attach metadata to a line.",               "# Tag ",          "⌘⇧T",  CmdShift | (int)BlazorMonaco.KeyCode.KeyT)
    };

    private bool _functionsOpen;

    private async Task InsertFunction(string snippet)
    {
        _functionsOpen = false;
        await AddInkElement(snippet);
    }

    private static string ElementTooltip(InkSnippet element) =>
        element.Shortcut is null ? element.Tooltip : $"{element.Tooltip} ({element.Shortcut})";

    /// <summary>Binds the toolbar snippets to editor-scoped shortcuts. Monaco actions
    /// only fire while the editor has focus, so they never shadow app-wide keys.</summary>
    private async Task RegisterEditorShortcuts()
    {
        if (_editor is null) return;
        foreach (var element in InkElements)
        {
            if (element.Keybinding is not int keybinding) continue;
            await _editor.AddAction(new ActionDescriptor
            {
                Id = $"ink-insert-{element.Label.ToLowerInvariant()}",
                Label = $"Insert {element.Label}",
                Keybindings = [keybinding],
                ContextMenuGroupId = "ink",
                Run = editor => _ = InvokeAsync(() => AddInkElement(element.Snippet))
            });
        }
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        InkStoryService.InkScriptSelected += UpdateEditorContent;
        InkStoryService.CompileStateChanged += OnCompileStateChanged;
        StorageService.FilesLoaded += LoadMainInkScript;
    }

    private void OnCompileStateChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync(identifier: "registerInkLanguage");
        }
    }

    private async Task AddInkElement(string element)
    {
        if (_editor is null) return;
        await _editor.SetPosition(_currentCursorPosition, element);
        await _editor.Trigger("addInkElement", "type", new { text = $"{element}" });
        await _editor.Focus();
    }

    private void LoadMainInkScript(IEnumerable<string> files)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                var filePath = files?.FirstOrDefault(file => file == MainInkScriptPath);
                if (ScriptExists(filePath))
                {
                    var content = await StorageService.ReadFileAsTextAsync(filePath!);
                    InkStoryService.ActiveScriptPath = MainInkScriptPath;
                    await ApplyContentAsync(content);
                    InkStoryService.InkScriptSelected?.Invoke(content);

                    // Auto-run the freshly imported project's main script in the runner.
                    if (StorageService.Root is not null)
                    {
                        InkStoryService.Run(StorageService.Root, MainInkScriptPath);
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"LoadMainInkScript failed: {ex}");
            }
        });
    }

    private async Task OnModelContentChanged(ModelContentChangedEvent e)
    {
        if (_editor is null) return;
        var content = await _editor.GetValue();
        InkStoryService.SetContent(content);
        await SaveContentToFile(content);
        ScheduleCompile();
        StateHasChanged();
    }

    /// <summary>Recompiles the script shortly after the user stops typing so state and errors stay live.</summary>
    private void ScheduleCompile()
    {
        _compileCts?.Cancel();
        var cts = _compileCts = new CancellationTokenSource();
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(CompileDebounceMs, cts.Token);
            }
            catch (TaskCanceledException)
            {
                return;
            }
            await InvokeAsync(() =>
            {
                if (StorageService.Root is null) return;
                InkStoryService.Compile(StorageService.Root, InkStoryService.ActiveScriptPath);
            });
        });
    }

    private void UpdateEditorContent(string content)
    {
        _ = InvokeAsync(() => ApplyContentAsync(content));
    }

    private async Task ApplyContentAsync(string content)
    {
        try
        {
            InkStoryService.SetContent(content ?? string.Empty);
            if (_editor is not null)
            {
                await _editor.SetValue(content ?? string.Empty);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ApplyContentAsync failed: {ex}");
        }
    }

    private async Task SaveContentToFile(string content)
    {
        await StorageService.WriteFileAsync(InkStoryService.ActiveScriptPath, content);
    }

    private void EditorDidChangeCursorPosition(CursorPositionChangedEvent eventArgs)
    {
        _currentCursorPosition = eventArgs.Position;
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {

        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            WordWrap = "on",
            WrappingStrategy = "advanced",
            WordBreak = "normal",
            Minimap = new EditorMinimapOptions { Enabled = false },
            Language = "ink",
            Theme = "ink-dark",
            FontSize = 15,
            FontFamily = "RobotoMono, 'JetBrains Mono', 'Fira Code', Menlo, monospace",
            LineHeight = 24,
            Value = InkStoryService.EditorContent,
        };
    }

    private bool ScriptExists(string? scriptPath)
    {
        return !string.IsNullOrWhiteSpace(scriptPath);
    }

    public override void Dispose()
    {
        base.Dispose();
        _compileCts?.Cancel();
        _editor?.Dispose();
        InkStoryService.InkScriptSelected -= UpdateEditorContent;
        InkStoryService.CompileStateChanged -= OnCompileStateChanged;
        StorageService.FilesLoaded -= LoadMainInkScript;
    }
}
