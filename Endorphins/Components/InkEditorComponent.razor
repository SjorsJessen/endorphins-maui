@inject IJSRuntime JS
@inject InkStoryService InkStoryService;
@inject FileStorageService StorageService;
@inherits DevHotReloadComponentBase;

<MudToolBar Dense Style="display: flex; align-items: center; gap: 10px">
    @foreach (var element in InkElements)
    {
        <MudButton
            Variant="Variant.Text"
            Color="Color.Inherit"
            Size="Size.Small"
            HtmlTag="label"
            OnClick="() => AddInkElement(element.Value)">
            @element.Key
        </MudButton>
    }
</MudToolBar>

<StandaloneCodeEditor
    @ref="_editor"
    CssClass="ink-editor"
    ConstructionOptions="EditorConstructionOptions"
    OnDidChangeModelContent="OnModelContentChanged"
    OnDidChangeCursorPosition="EditorDidChangeCursorPosition" 
/>

@code {
    private const string InkScriptsDirectory = "scripts";
    private const string MainInkScriptPath = $"{InkScriptsDirectory}/main.ink";
    private StandaloneCodeEditor? _editor;
    private BlazorMonaco.Position _currentCursorPosition = new();
    private Dictionary<string, string> InkElements = new()
    {
        { "=== knot", "=== knot === \n" },
        { "= stitch", "= stitch = \n " },
        { "-> divert", "-> divert \n" },
        { "* choice", "* choice \n" },
        { "VAR variable ", "VAR " },
        { "# Tag ", "# Tag " }
    };

    protected override void OnInitialized()
    {
        base.OnInitialized();
        InkStoryService.InkScriptSelected += UpdateEditorContent;
        StorageService.FilesLoaded += LoadMainInkScript;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync(identifier: "registerInkLanguage");
        }
    }

    private async Task AddInkElement(string element)
    {
        if (_editor is null) return;
        await _editor.SetPosition(_currentCursorPosition, element);
        await _editor.Trigger("addInkElement", "type", new { text = $"{element}" });
        await _editor.Focus();
    }

    private void LoadMainInkScript(IEnumerable<string> files)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                var filePath = files?.FirstOrDefault(file => file == MainInkScriptPath);
                if (ScriptExists(filePath))
                {
                    var content = await StorageService.ReadFileAsTextAsync(filePath!);
                    InkStoryService.ActiveScriptPath = MainInkScriptPath;
                    await ApplyContentAsync(content);
                    InkStoryService.InkScriptSelected?.Invoke(content);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"LoadMainInkScript failed: {ex}");
            }
        });
    }

    private async Task OnModelContentChanged(ModelContentChangedEvent e)
    {
        if (_editor is null) return;
        var content = await _editor.GetValue();
        InkStoryService.SetContent(content);
        await SaveContentToFile(content);
        StateHasChanged();
    }

    private void UpdateEditorContent(string content)
    {
        _ = InvokeAsync(() => ApplyContentAsync(content));
    }

    private async Task ApplyContentAsync(string content)
    {
        try
        {
            InkStoryService.SetContent(content ?? string.Empty);
            if (_editor is not null)
            {
                await _editor.SetValue(content ?? string.Empty);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ApplyContentAsync failed: {ex}");
        }
    }

    private async Task SaveContentToFile(string content)
    {
        await StorageService.WriteFileAsync(InkStoryService.ActiveScriptPath, content);
    }

    private void EditorDidChangeCursorPosition(CursorPositionChangedEvent eventArgs)
    {
        _currentCursorPosition = eventArgs.Position;
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {

        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "ink",
            Theme = "ink-dark",
            FontSize = 16,
            Value = InkStoryService.EditorContent,
        };
    }

    private bool ScriptExists(string? scriptPath)
    {
        return !string.IsNullOrWhiteSpace(scriptPath);
    }

    public override void Dispose()
    {
        base.Dispose();
        _editor?.Dispose();
        InkStoryService.InkScriptSelected -= UpdateEditorContent;
        StorageService.FilesLoaded -= LoadMainInkScript;
    }
}
