@using Endorphins.Models

@inject IJSRuntime JS
@implements IAsyncDisposable
@inherits DevHotReloadComponentBase;

<div @ref="_viewport" class="viewport"
     style="position:relative;width:100%;height:600px;overflow:hidden;
            background:#1e1e1e;touch-action:none;"
     @onpointerdown="StartPan"
     @onpointermove="OnMove"
     @onpointerup="EndInteraction"
     @onpointerleave="EndInteraction"
     @onwheel="OnWheel" @onwheel:preventDefault="true">

    <div class="world"
         style="position:absolute;left:0;top:0;transform-origin:0 0;
             transform:translate(@(_panX)px,@(_panY)px) scale(@_scale);">

        @foreach (var item in _model.Items)
        {
            <div style="position:absolute;
                left:@(item.X)px;top:@(item.Y)px;
            width:@(item.Width)px;height:@(item.Height)px;
            z-index:@item.ZIndex;transform:rotate(@(item.Rotation)deg);
            cursor:move;"
                 @onpointerdown:stopPropagation="true"
                 @onpointerdown="e => StartDrag(e, item)">

                <img src="@item.ImageUrl"
                     alt="moodboard"
                     style="width:100%;height:100%;object-fit:cover;
                            pointer-events:none;user-select:none;"/>

                <div style="position:absolute;right:0;bottom:0;width:14px;height:14px;
                            background:#4af;cursor:nwse-resize;"
                     @onpointerdown:stopPropagation="true"
                     @onpointerdown="e => StartResize(e, item)"></div>
            </div>
        }
    </div>
</div>

@code {
    private MoodboardModel _model = new();
    private ElementReference _viewport;
    private IJSObjectReference? _module;
    private double _rectLeft, _rectTop;

    // viewport
    private double _panX, _panY, _scale = 1.0;

    // interaction
    private enum Mode
    {
        None,
        Drag,
        Resize,
        Pan
    }

    private Mode _mode = Mode.None;
    private MoodboardItem? _active;
    private double _lastX, _lastY;
    private DotNetObjectReference<MoodboardComponent> _self;

    protected override void OnInitialized()
    {
        _model.Items.Add(new MoodboardItem
        {
            ImageUrl = "https://picsum.photos/300/200", X = 60, Y = 60, ZIndex = 1
        });
        _model.Items.Add(new MoodboardItem
        {
            ImageUrl = "https://picsum.photos/250/250", X = 260, Y = 180, ZIndex = 2
        });
        _model.NextZ = 3;
    }


    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        _module = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./js/boardInterop.js");
        await RefreshRect();

        _self = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("initImport", _viewport, _self);
    }

// Convert a screen point to world coordinates
    private (double x, double y) ScreenToWorld(double clientX, double clientY)
    {
        var sx = clientX - _rectLeft;
        var sy = clientY - _rectTop;
        return ((sx - _panX) / _scale, (sy - _panY) / _scale);
    }

    private void AddAt(string url, double worldX, double worldY)
    {
        _model.Items.Add(new MoodboardItem
        {
            ImageUrl = url,
            X = worldX, Y = worldY,
            Width = 200, Height = 200,      // resized on load below
            ZIndex = _model.NextZ++
        });
    }

    [JSInvokable]
    public async Task OnImagesDropped(string[] urls, double clientX, double clientY)
    {
        var (wx, wy) = ScreenToWorld(clientX, clientY);
        foreach (var url in urls)
        {
            AddAt(url, wx, wy);
            wx += 24; wy += 24;             // cascade multiples
        }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnImagesPasted(string[] urls)
    {
        // paste has no cursor point — drop at center of current view
        var cx = _rectLeft + 300;           // ~viewport center-ish
        var (wx, wy) = ScreenToWorld(cx, _rectTop + 300);
        foreach (var url in urls)
        {
            AddAt(url, wx, wy);
            wx += 24; wy += 24;
        }
        StateHasChanged();
    }

    private async Task RefreshRect()
    {
        var r = await _module!.InvokeAsync<double[]>("getRect", _viewport);
        _rectLeft = r[0];
        _rectTop = r[1];
    }

    private void StartDrag(PointerEventArgs e, MoodboardItem item)
    {
        _mode = Mode.Drag;
        _active = item;
        _lastX = e.ClientX;
        _lastY = e.ClientY;
        item.ZIndex = _model.NextZ++;
    }

    private void StartResize(PointerEventArgs e, MoodboardItem item)
    {
        _mode = Mode.Resize;
        _active = item;
        _lastX = e.ClientX;
        _lastY = e.ClientY;
    }

    // fires on empty space because items stopPropagation
    private void StartPan(PointerEventArgs e)
    {
        _mode = Mode.Pan;
        _lastX = e.ClientX;
        _lastY = e.ClientY;
    }

    private void OnMove(PointerEventArgs e)
    {
        if (_mode == Mode.None) return;
        var dx = e.ClientX - _lastX;
        var dy = e.ClientY - _lastY;
        _lastX = e.ClientX;
        _lastY = e.ClientY;

        switch (_mode)
        {
            case Mode.Pan:
                _panX += dx;
                _panY += dy; // screen space
                break;
            case Mode.Drag:
                _active!.X += dx / _scale; // world space
                _active.Y += dy / _scale;
                break;
            case Mode.Resize:
                _active!.Width = Math.Max(20, _active.Width + dx / _scale);
                _active.Height = Math.Max(20, _active.Height + dy / _scale);
                break;
        }
    }

    private void EndInteraction(PointerEventArgs e)
    {
        _mode = Mode.None;
        _active = null;
    }

    // zoom toward cursor
    private void OnWheel(WheelEventArgs e)
    {
        var old = _scale;
        var next = Math.Clamp(old * (e.DeltaY < 0 ? 1.1 : 1 / 1.1), 0.1, 10);

        var cx = e.ClientX - _rectLeft; // cursor relative to viewport
        var cy = e.ClientY - _rectTop;
        var worldX = (cx - _panX) / old; // world point under cursor
        var worldY = (cy - _panY) / old;

        _panX = cx - worldX * next; // keep that point fixed
        _panY = cy - worldY * next;
        _scale = next;
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null) await _module.DisposeAsync();
        _self?.Dispose();
    }

}