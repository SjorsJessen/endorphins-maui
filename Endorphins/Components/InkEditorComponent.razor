@inject IJSRuntime JS
@inject InkStoryService InkStoryService;
@implements IDisposable;

<StandaloneCodeEditor
    @ref="_editor"
    CssClass="ink-editor"
    ConstructionOptions="EditorConstructionOptions"
    OnDidChangeModelContent="UpdateEditorContent"
/>

@code {
    private StandaloneCodeEditor? _editor;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        InkStoryService.InkScriptSelected += UpdateEditorContent;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("registerInkLanguage");
        }
    }
    
    private async void UpdateEditorContent(ModelContentChangedEvent e)
    {
        if (_editor == null) return;
        var content = await _editor.GetValue();
        InkStoryService.SetContent(content);
        StateHasChanged();
    }    
    
    private async void UpdateEditorContent(string content)
    {
        InkStoryService.SetContent(content);
        await _editor?.SetValue(content)!;
        StateHasChanged();
    }
    
    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {

        return new StandaloneEditorConstructionOptions{
            AutomaticLayout = true,
            Language = "ink",
            Theme = "ink-dark",
            Value = InkStoryService.EditorContent,
        };
    }

    public void Dispose()
    {
        _editor?.Dispose();
        InkStoryService.InkScriptSelected -= UpdateEditorContent;
    }
}