@using Endorphins.Services
@using MudBlazor

@inject InkStoryService InkStoryService;
@inherits DevHotReloadComponentBase;

<MudToolBar Fixed="false" Dense>
    <div class="app-logo">
        <img srcset="Assets/endorphins-icon.svg" alt="logo" width="32px" height="32px"/>
        <span class="app-name">Endorphins_</span>
    </div>
    <MudSpacer/>
    <div class="ink-state @StateClass">
        <span class="ink-state-dot"></span>
        <span class="ink-state-text">@StateLabel</span>
    </div>
</MudToolBar>
<MudDivider/>

@code
{
    private string StateClass => InkStoryService.CompileState switch
    {
        InkCompileState.Compiling => "is-compiling",
        InkCompileState.Compiled => "is-compiled",
        InkCompileState.Error => "is-error",
        _ => "is-idle",
    };

    private string StateLabel => InkStoryService.CompileState switch
    {
        InkCompileState.Compiling => "Compiling…",
        InkCompileState.Compiled => "Compiled",
        InkCompileState.Error => ErrorLabel,
        _ => "No story loaded",
    };

    private string ErrorLabel
    {
        get
        {
            var errors = InkStoryService.Diagnostics.Count(d => d.Type == Ink.ErrorType.Error);
            return errors == 1 ? "1 error" : $"{errors} errors";
        }
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        InkStoryService.CompileStateChanged += OnCompileStateChanged;
    }

    private void OnCompileStateChanged() => InvokeAsync(StateHasChanged);

    public override void Dispose()
    {
        base.Dispose();
        InkStoryService.CompileStateChanged -= OnCompileStateChanged;
    }
}
