@inject AssetsService AssetsService;
@inject FileStorageService StorageService;
@implements IDisposable;
@inherits DevHotReloadComponentBase;

<div class="markdown-editor">
    <MarkdownEditor 
        @ref="_editor" 
        Value="@Content" 
        ValueChanged="OnContentChanged" 
        MaxHeight="100vh"
    />
</div>

@code
{
    private MarkdownEditor? _editor;
    private string Content { get; set; } = string.Empty;
    private string _activeFile = string.Empty;
    
    protected override void OnInitialized()
    {
        base.OnInitialized();
        AssetsService.MarkdownFileSelected += OnMarkdownFileSelect;
        if (AssetsService.ActiveMarkdownPath is not null)
        {
            _activeFile = AssetsService.ActiveMarkdownPath;
            Content = AssetsService.ActiveMarkdownContent;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _editor is not null && !string.IsNullOrEmpty(Content))
        {
            await _editor.SetValueAsync(Content);
        }
    }

    private void OnMarkdownFileSelect(string filePath, string newContent)
    {
        _activeFile = filePath;
        InvokeAsync(async () =>
        {
            Content = newContent;
            if (_editor is not null)
            {
                await _editor.SetValueAsync(newContent);
            }
            StateHasChanged();
        });
    }

    private void OnContentChanged(string newContent)
    {
        Content = newContent;
        StorageService.WriteFileAsync(relativePath: _activeFile, content: newContent);
        AssetsService.UpdateMarkdownContent(newContent);
    }

    public void Dispose()
    {
        AssetsService.MarkdownFileSelected -= OnMarkdownFileSelect;
    }
}